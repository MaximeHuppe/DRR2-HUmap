# Compute reconstruction metrics
print("📊 Computing reconstruction metrics...")

def compute_reconstruction_metrics(pred_ct, gt_ct, threshold=THRESHOLD):
    """Compute various metrics for CT reconstruction quality"""
    
    # Apply threshold mask (only evaluate on tissue regions)
    mask = gt_ct > threshold
    
    if np.sum(mask) == 0:
        print("⚠️ No valid voxels above threshold")
        return {}
    
    pred_masked = pred_ct[mask]
    gt_masked = gt_ct[mask]
    
    # Basic metrics
    mae = np.mean(np.abs(pred_masked - gt_masked))
    rmse = np.sqrt(np.mean((pred_masked - gt_masked) ** 2))
    
    # Correlation
    correlation = np.corrcoef(pred_masked, gt_masked)[0, 1]
    
    # Relative error
    relative_error = np.mean(np.abs(pred_masked - gt_masked) / (np.abs(gt_masked) + 1e-8))
    
    # Peak Signal-to-Noise Ratio
    mse = np.mean((pred_masked - gt_masked) ** 2)
    if mse > 0:
        psnr = 10 * np.log10((1000 - threshold)**2 / mse)  # Using HU range
    else:
        psnr = float('inf')
    
    return {
        'mae': mae,
        'rmse': rmse,
        'correlation': correlation,
        'relative_error': relative_error,
        'psnr': psnr,
        'n_voxels': np.sum(mask)
    }

# Compute metrics
