# CNN-PCA Model Architecture (from original implementation)
class MCDropout(nn.Dropout):
    """Monte Carlo Dropout for uncertainty estimation"""
    def forward(self, x): 
        return F.dropout(x, self.p, training=True, inplace=self.inplace)

class PC1Regressor(nn.Module):
    """CNN-PCA Model for predicting single PC coefficient (ResNet18-based)"""
    def __init__(self):
        super().__init__()
        # Use ResNet18 backbone with 2-channel input (AP + ML)
        base = tv_models.resnet18(weights=None)
        base.conv1 = nn.Conv2d(2, 64, 7, 2, 3, bias=False)  # 2 channels for AP+ML
        self.backbone = nn.Sequential(*list(base.children())[:-1])
        self.head = nn.Sequential(
            nn.Linear(512, 256), 
            nn.ReLU(),
            MCDropout(DROPOUT_RATE),
            nn.Linear(256, 1)
        )
    
    def forward(self, x):
        f = self.backbone(x).view(x.size(0), -1)
        return self.head(f).squeeze(1)

def predict_pcs_with_uncertainty(drr, models, n_samples=20):
    """
    Predict PC coefficients with uncertainty estimation using Monte Carlo Dropout
    
    Args:
        drr: DRR tensor of shape (2, H, W) - AP and ML views stacked
        models: List of trained PC models
        n_samples: Number of MC dropout samples for uncertainty estimation
    
    Returns:
        pred_pcs: Mean predicted PC coefficients
        pred_std: Standard deviation of predictions (uncertainty)
    """
    pred_pcs = []
    pred_stds = []
    
    with torch.no_grad():
        for model in models:
            # Get multiple predictions with MC dropout
            draws = torch.stack([model(drr[None].to(DEVICE)) for _ in range(n_samples)])
            
            # Calculate mean and std
            mean_pred = draws.mean(0).cpu().numpy()[0]
            std_pred = draws.std(0).cpu().numpy()[0]
            
            pred_pcs.append(mean_pred)
            pred_stds.append(std_pred)
    
    return np.array(pred_pcs), np.array(pred_stds)

def reconstruct_ct_volume(pred_pcs, pca, scaler, idx, ct_shape=CT_SHAPE):
    """
    Reconstruct 3D CT volume from predicted PC coefficients
    
    Args:
        pred_pcs: Predicted PC coefficients
        pca: Fitted PCA model
        scaler: Fitted StandardScaler
        idx: Voxel indices for reconstruction
        ct_shape: Shape of output CT volume
    
    Returns:
        pred_ct: Reconstructed 3D CT volume
    """
    # Pad PC coefficients to full size if needed
    full_pred_pcs = np.zeros(NUM_PCA_MODES)
    full_pred_pcs[:len(pred_pcs)] = pred_pcs
    
    # Inverse transform: PCs → Voxels
    pred_vox = pca.inverse_transform(scaler.inverse_transform(full_pred_pcs.reshape(1, -1))).reshape(-1)
    
    # Reconstruct 3D volume
    pred_ct = np.zeros(ct_shape, dtype=np.float32)
    pred_ct.flat[idx] = pred_vox
    
    return pred_ct

