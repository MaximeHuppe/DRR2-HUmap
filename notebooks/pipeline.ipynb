def plot_ct_slices(pred_ct, gt_ct, slice_indices=None, title_prefix=""):
    """Plot CT slices in all three orientations"""
    if slice_indices is None:
        # Select middle slices
        slice_indices = [
            pred_ct.shape[0] // 2,  # Axial
            pred_ct.shape[1] // 2,  # Coronal  
            pred_ct.shape[2] // 2   # Sagittal
        ]
    
    fig, axes = plt.subplots(3, 2, figsize=(12, 15))
    
    orientations = ['Axial', 'Coronal', 'Sagittal']
    
    for i, (orientation, slice_idx) in enumerate(zip(orientations, slice_indices)):
        # Get slices
        if i == 0:  # Axial
            pred_slice = pred_ct[slice_idx, :, :]
            gt_slice = gt_ct[slice_idx, :, :]
        elif i == 1:  # Coronal
            pred_slice = pred_ct[:, slice_idx, :]
            gt_slice = gt_ct[:, slice_idx, :]
        else:  # Sagittal
            pred_slice = pred_ct[:, :, slice_idx]
            gt_slice = gt_ct[:, :, slice_idx]
        
        # Plot predicted
        im1 = axes[i, 0].imshow(pred_slice, cmap='gray', vmin=-1000, vmax=1000)
        axes[i, 0].set_title(f'{title_prefix}Predicted {orientation} (slice {slice_idx})')
        axes[i, 0].axis('off')
        plt.colorbar(im1, ax=axes[i, 0], fraction=0.046, pad=0.04)
        
        # Plot ground truth
        im2 = axes[i, 1].imshow(gt_slice, cmap='gray', vmin=-1000, vmax=1000)
        axes[i, 1].set_title(f'{title_prefix}Ground Truth {orientation} (slice {slice_idx})')
        axes[i, 1].axis('off')
        plt.colorbar(im2, ax=axes[i, 1], fraction=0.046, pad=0.04)
    
    plt.tight_layout()
    plt.show()

